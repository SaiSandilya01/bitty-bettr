# Copy this to .env and fill in your values

# -----------------------------------------------
# LLM Provider — choose one: gemini | openai
# -----------------------------------------------
LLM_PROVIDER=gemini

# --- Gemini (default) ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- OpenAI (alternative) ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: override the model
# Gemini options:  gemini-2.0-flash (default), gemini-1.5-pro, gemini-1.5-flash
# OpenAI options:  gpt-4o-mini (default), gpt-4o, gpt-3.5-turbo
LLM_MODEL=gemini-2.0-flash

# -----------------------------------------------
# Phase 6: Email to Kindle
# -----------------------------------------------
KINDLE_EMAIL=your_device@kindle.com
SMTP_USER=your_email@gmail.com
# For Gmail, you MUST use an App Password, not your real account password
SMTP_PASSWORD=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
